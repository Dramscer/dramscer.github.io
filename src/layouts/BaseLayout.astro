---
// src/layouts/BaseLayout.astro
const { title = "Luis Gabriel | Portafolio" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <title>{title}</title>
</head>
<body>
    <slot /> 

    <script>
        const configurarAnimaciones = () => {
            const elementosAanimar = document.querySelectorAll('.animate-on-scroll');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                        observer.unobserve(entry.target); // Animación de un solo viaje
                    }
                });
            }, {
                threshold: 0.05,
                rootMargin: "0px 0px -30px 0px"
            });

            elementosAanimar.forEach(el => observer.observe(el));
        };

        // Se ejecuta al cargar la página y al cambiar de ruta con transiciones de Astro
        configurarAnimaciones();
        document.addEventListener('astro:after-swap', configurarAnimaciones);
    </script>
</body>
</html>

<style is:global>
    /* --- CONFIGURACIÓN BASE DEL ENTORNO OSCURO --- */
    :root {
        color-scheme: dark;
    }

    html, body {
        background-color: #121212 !important;
        color: #ffffff !important;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        overflow-x: hidden;
        scroll-behavior: smooth;
    }

    *, *:before, *:after {
        box-sizing: inherit;
    }

    /* --- SISTEMA DE ESTRUCTURACIÓN EN MALLAS COMPACTAS (GRIDS) --- */
    .skills-grid, .projects-grid, .extras-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-top: 1.25rem;
        width: 100%;
    }

    /* Diseños de proyectos ligeramente más amplios para el código de Git */
    .projects-grid {
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    }

    /* --- DISEÑO ORIGINAL DE LAS TARJETAS PREMIUM --- */
    .skill-card, .project-card, .extra-card {
        background: #1e1e1e !important; /* Gris oscuro sólido original */
        border: 1px solid #2a2a2a !important;
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), 
                    border-color 0.25s ease, 
                    box-shadow 0.25s ease;
    }

    /* --- HOVERS CON BORDES NEÓN PERSONALIZADOS INDIVIDUALES --- */
    
    /* 1. Tarjeta de Lenguajes / Bloques de Proyectos (Verde Neón) */
    .skills-grid > .skill-card:nth-child(1):hover, 
    .project-card:hover {
        transform: translateY(-5px);
        border-color: #00ff66 !important;
        box-shadow: 0 8px 25px rgba(0, 255, 102, 0.12);
    }

    /* 2. Tarjeta de Frameworks & Plataformas (Azul Neón) */
    .skills-grid > .skill-card:nth-child(2):hover {
        transform: translateY(-5px);
        border-color: #00ccff !important;
        box-shadow: 0 8px 25px rgba(0, 204, 255, 0.12);
    }

    /* 3. Tarjeta de Herramientas / Bloques de Extras (Morado Neón) */
    .skills-grid > .skill-card:nth-child(3):hover, 
    .extra-card:hover {
        transform: translateY(-5px);
        border-color: #cc66ff !important;
        box-shadow: 0 8px 25px rgba(204, 102, 255, 0.12);
    }

    /* --- ESTILOS DE TEXTO INTERNOS --- */
    .skill-card h4, .project-card h4, .extra-card h5 {
        margin: 0;
        font-size: 1.3rem;
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    .skill-card p, .project-card p, .extra-card p {
        margin: 0;
        color: #b3b3b3;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    /* --- ENLACES INTERNOS DE PROYECTOS (BOTÓN GITHUB) --- */
    .project-link {
        align-self: flex-start; /* Evita que el enlace se estire horizontalmente */
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: auto; /* Lo empuja siempre al fondo de la tarjeta */
        padding-top: 0.75rem;
        color: #00ff66;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s ease;
    }

    .project-link:hover {
        color: #ffffff;
        text-decoration: underline;
    }

    /* --- ANIMACIONES DE DESPLAZAMIENTO (SCROLL) --- */
    .animate-on-scroll {
        opacity: 0;
        transform: translateY(25px);
        transition: opacity 0.7s cubic-bezier(0.2, 0.8, 0.2, 1), 
                    transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
        will-change: opacity, transform;
    }

    .animate-on-scroll.is-visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>