---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Gabriel García | Android Developer">
    <main class="portfolio-container">
        <section class="profile-section animate-on-scroll">
            <div class="profile-header">
                <img src="/profile.png" alt="Luis Gabriel García Carmona" class="profile-img" />
                <div class="profile-text">
                    <h1 class="profile-name">Luis Gabriel García Carmona</h1>
                    <p class="profile-tagline">Android Developer ~ Software Engineering Candidate</p>
                    <p class="profile-description">
                        Candidato a Ingeniería en Sistemas Computacionales entrando a la fase de proyecto de titulación con promedio de excelencia (97.4). Combino experiencia profesional en banca con un rol actual de liderazgo técnico y QA remoto.
                    </p>
                </div>
            </div>
        </section>

        <section class="skills-section animate-on-scroll">
            <div class="skills-grid">
                <div class="skill-card">
                    <h4 class="text-neon-green">Lenguajes</h4>
                    <p>Kotlin, Java, Python, SQL, HTML5/CSS3, JavaScript</p>
                </div>
                <div class="skill-card">
                    <h4 class="text-neon-blue">Frameworks & Plataformas</h4>
                    <p>Android SDK, Astro, Firebase (Auth, Firestore, Realtime DB), Room Database</p>
                </div>
                <div class="skill-card">
                    <h4 class="text-neon-purple">Herramientas & DevOps</h4>
                    <p>Git, GitHub, VS Code, Android Studio</p>
                </div>
            </div>
        </section>

        <section class="projects-section animate-on-scroll">
            <h3 class="section-title">Proyectos Destacados</h3>
            <div id="projects-container" class="projects-grid">
                <p class="loading-text">Cargando proyectos desde Firebase...</p>
            </div>
        </section>

        <section class="extras-section animate-on-scroll">
            <h3 class="section-title">Más allá del código</h3>
            <div id="extras-container" class="extras-grid">
                <p class="loading-text">Cargando pasatiempos...</p>
            </div>
        </section>
    </main>
</BaseLayout>

<script>
    import { db } from '../lib/firebase';
    import { collection, onSnapshot } from 'firebase/firestore';

    // === 1. ESCUCHAR Y RENDERIZAR PROYECTOS ===
    const projectsContainer = document.getElementById('projects-container');
    
    if (projectsContainer) {
        onSnapshot(collection(db, 'projects'), (snapshot) => {
            if (snapshot.empty) {
                projectsContainer.innerHTML = '<p class="empty-text">No hay proyectos disponibles en este momento.</p>';
                return;
            }
            
            let html = '';
            snapshot.forEach((doc) => {
                const data = doc.data();
                html += `
                    <div class="project-card animate-on-scroll is-visible">
                        <h4>${data.title || 'Proyecto sin título'}</h4>
                        <p>${data.description || 'Sin descripción disponible.'}</p>
                        ${data.link ? `
                            <a href="${data.link}" target="_blank" class="project-link">
                                <i class="fab fa-github"></i> Ver Código
                            </a>
                        ` : ''}
                    </div>
                `;
            });
            projectsContainer.innerHTML = html;
        });
    }

    // === 2. ESCUCHAR Y RENDERIZAR MÁS ALLÁ DEL CÓDIGO ===
    const extrasContainer = document.getElementById('extras-container');
    
    if (extrasContainer) {
        onSnapshot(collection(db, 'extras'), (snapshot) => {
            if (snapshot.empty) {
                extrasContainer.innerHTML = '<p class="empty-text">Agrega habilidades blandas o pasatiempos desde el panel administrador.</p>';
                return;
            }
            
            let html = '';
            snapshot.forEach((doc) => {
                const data = doc.data();
                html += `
                    <div class="extra-card animate-on-scroll is-visible">
                        <h5>${data.name || 'Actividad'}</h5>
                        <p>${data.detail || ''}</p>
                    </div>
                `;
            });
            extrasContainer.innerHTML = html;
        });
    }
</script>

<style>
    /* Estilos base de ordenamiento para asegurar que las mallas se pinten impecables */
    .portfolio-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    .section-title {
        font-size: 1.8rem;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid #222;
        padding-bottom: 0.5rem;
    }

    .loading-text, .empty-text {
        color: #666;
        font-style: italic;
        grid-column: 1 / -1;
    }

    /* Colores neón personalizados para los títulos de tus habilidades fijas */
    .text-neon-green { color: #00ff66; }
    .text-neon-blue  { color: #00ccff; }
    .text-neon-purple { color: #cc66ff; }
</style>