---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Gabriel García | Android Developer">
    <main class="portfolio-container">
        <section class="profile-section animate-on-scroll">
            <div class="profile-header">
                <img src="/profile.png" alt="Luis Gabriel García Carmona" class="profile-img" />
                <div class="profile-text">
                    <h1 class="profile-name">Luis Gabriel García Carmona</h1>
                    <p class="profile-tagline">Android Developer ~ Software Engineering Candidate</p>
                    <p class="profile-description">
                        Candidato a Ingeniería en Sistemas Computacionales entrando a la fase de proyecto de titulación con promedio de excelencia (97.4). Combino experiencia profesional en banca con un rol actual de liderazgo técnico y QA remoto.
                    </p>
                    
                    <div id="links-container" class="social-links-container">
                        </div>
                </div>
            </div>
        </section>

        <section class="skills-section animate-on-scroll">
            <div class="skills-grid">
                <div class="skill-card-static">
                    <h4 class="text-neon-green">Lenguajes</h4>
                    <p>Kotlin, Java, Python, SQL, HTML5/CSS3, JavaScript</p>
                </div>
                <div class="skill-card-static">
                    <h4 class="text-neon-blue">Frameworks & Plataformas</h4>
                    <p>Android SDK, Astro, Firebase (Auth, Firestore, Realtime DB), Room Database</p>
                </div>
                <div class="skill-card-static">
                    <h4 class="text-neon-purple">Herramientas & DevOps</h4>
                    <p>Git, GitHub, VS Code, Android Studio</p>
                </div>
            </div>
        </section>

        <section class="projects-section animate-on-scroll">
            <h3 class="section-title">Proyectos Destacados</h3>
            <div id="projects-container" class="projects-grid">
                <p class="loading-text">Cargando proyectos desde Firebase...</p>
            </div>
        </section>

        <section class="extras-section animate-on-scroll">
            <h3 class="section-title">Más allá del código</h3>
            <div id="extras-container" class="extras-grid">
                <p class="loading-text">Cargando pasatiempos...</p>
            </div>
        </section>
    </main>
</BaseLayout>

<script>
    import { db } from '../lib/firebase';
    import { collection, onSnapshot } from 'firebase/firestore';

    // === 1. ESCUCHAR ENLACES / REDES SOCIALES ===
    const linksContainer = document.getElementById('links-container');
    if (linksContainer) {
        onSnapshot(collection(db, 'links'), (snapshot) => {
            let html = '';
            snapshot.forEach((doc) => {
                const data = doc.data();
                const esGithub = data.name?.toLowerCase().includes('github');
                const icono = esGithub ? '<i class="fab fa-github"></i>' : '<i class="fas fa-link"></i>';
                
                html += `
                    <a href="${data.url || '#'}" target="_blank" class="social-link-btn">
                        ${icono} <span>${data.name || 'Enlace'}</span>
                    </a>
                `;
            });
            linksContainer.innerHTML = html;
        });
    }

    // === 2. ESCUCHAR PROYECTOS ===
    const projectsContainer = document.getElementById('projects-container');
    if (projectsContainer) {
        onSnapshot(collection(db, 'projects'), (snapshot) => {
            if (snapshot.empty) {
                projectsContainer.innerHTML = '<p class="empty-text">No hay proyectos disponibles en este momento.</p>';
                return;
            }
            
            let html = '';
            snapshot.forEach((doc) => {
                const data = doc.data();
                html += `
                    <div class="project-card">
                        <h4>${data.title || 'Proyecto sin título'}</h4>
                        <p>${data.description || 'Sin descripción disponible.'}</p>
                        ${data.link ? `
                            <a href="${data.link}" target="_blank" class="project-link">
                                <i class="fab fa-github"></i> Ver Código
                            </a>
                        ` : ''}
                    </div>
                `;
            });
            projectsContainer.innerHTML = html;
        });
    }

    // === 3. ESCUCHAR MÁS ALLÁ DEL CÓDIGO ===
    const extrasContainer = document.getElementById('extras-container');
    if (extrasContainer) {
        onSnapshot(collection(db, 'extras'), (snapshot) => {
            if (snapshot.empty) {
                extrasContainer.innerHTML = '<p class="empty-text">Agrega habilidades blandas desde el panel administrador.</p>';
                return;
            }
            
            let html = '';
            snapshot.forEach((doc) => {
                const data = doc.data();
                html += `
                    <div class="extra-card">
                        <h5>${data.name || 'Actividad'}</h5>
                        <p>${data.detail || ''}</p>
                    </div>
                `;
            });
            extrasContainer.innerHTML = html;
        });
    }
</script>

<style>
    /* --- CONTENEDOR GENERAL --- */
    .portfolio-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }

    .section-title {
        font-size: 1.8rem;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid #222;
        padding-bottom: 0.5rem;
    }

    .text-neon-green { color: #00ff66; }
    .text-neon-blue  { color: #00ccff; }
    .text-neon-purple { color: #cc66ff; }
    .loading-text, .empty-text { color: #666; font-style: italic; }

    /* --- ESTILOS DE TUS TARJETAS ESTÁTICAS DE SKILLS --- */
    .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        width: 100%;
    }

    .skill-card-static {
        background: #1e1e1e;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .skills-grid > .skill-card-static:nth-child(1):hover {
        transform: translateY(-4px); border-color: #00ff66; box-shadow: 0 8px 20px rgba(0, 255, 102, 0.1);
    }
    .skills-grid > .skill-card-static:nth-child(2):hover {
        transform: translateY(-4px); border-color: #00ccff; box-shadow: 0 8px 20px rgba(0, 204, 255, 0.1);
    }
    .skills-grid > .skill-card-static:nth-child(3):hover {
        transform: translateY(-4px); border-color: #cc66ff; box-shadow: 0 8px 20px rgba(204, 102, 255, 0.1);
    }

    /* --- 🔗 BOTONES DE ENLACES INYECTADOS (Bajo el Perfil) --- */
    .social-links-container {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
    }

    :global(.social-link-btn) {
        display: inline-flex !important;
        align-items: center !important;
        gap: 0.6rem !important;
        background: #1e1e1e !important;
        border: 1px solid #2a2a2a !important;
        padding: 0.6rem 1.2rem !important;
        border-radius: 8px !important;
        color: #ffffff !important;
        text-decoration: none !important;
        font-size: 0.95rem !important;
        font-weight: 500 !important;
        transition: border-color 0.2s, color 0.2s, box-shadow 0.2s !important;
    }

    :global(.social-link-btn:hover) {
        border-color: #00ff66 !important;
        color: #00ff66 !important;
        box-shadow: 0 4px 12px rgba(0, 255, 102, 0.15) !important;
    }

    /* --- 📋 MALLAS Y TARJETAS DINÁMICAS (Proyectos y Extras) --- */
    .projects-grid, .extras-grid {
        display: grid !important;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)) !important;
        gap: 1.5rem !important;
        margin-top: 1.25rem !important;
        width: 100% !important;
    }

    :global(.project-card), :global(.extra-card) {
        background: #1e1e1e !important;
        border: 1px solid #2a2a2a !important;
        border-radius: 12px !important;
        padding: 1.5rem !important;
        display: flex !important;
        flex-direction: column !important;
        gap: 0.6rem !important;
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease !important;
    }

    :global(.project-card:hover) {
        transform: translateY(-4px) !important;
        border-color: #00ff66 !important;
        box-shadow: 0 8px 20px rgba(0, 255, 102, 0.1) !important;
    }

    :global(.extra-card:hover) {
        transform: translateY(-4px) !important;
        border-color: #cc66ff !important;
        box-shadow: 0 8px 20px rgba(204, 102, 255, 0.1) !important;
    }

    :global(.project-card h4), :global(.extra-card h5) {
        margin: 0 !important;
        font-size: 1.3rem !important;
        font-weight: 600 !important;
        color: #ffffff !important;
    }

    :global(.project-card p), :global(.extra-card p) {
        margin: 0 !important;
        color: #b3b3b3 !important;
        font-size: 0.95rem !important;
        line-height: 1.5 !important;
    }

    /* --- BOTÓN DE ENLACE DE CÓDIGO (GitHub en proyectos) --- */
    :global(.project-link) {
        align-self: flex-start !important;
        display: inline-flex !important;
        align-items: center !important;
        gap: 0.5rem !important;
        margin-top: auto !important;
        padding-top: 0.75rem !important;
        color: #00ff66 !important;
        text-decoration: none !important;
        font-size: 0.9rem !important;
        font-weight: 500 !important;
    }

    :global(.project-link:hover) {
        color: #ffffff !important;
        text-decoration: underline !important;
    }
</style>